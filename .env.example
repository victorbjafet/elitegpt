OPENAI_API_KEY=sk-your-key-here

# Set this to any long random string. The Watch Shortcut/app must send it too.
BRIDGE_TOKEN=change-me

# Good default for lower latency/cost. Override for your account/model preference.
OPENAI_MODEL=gpt-5.4-mini
MAX_OUTPUT_TOKENS=700
IMAGE_DETAIL=auto

# The prompt can be overridden per request from the Watch/client.
DEFAULT_PROMPT=Analyze the captured presentation screen and provide a concise response.

# FastAPI bind settings. Use 0.0.0.0 so your Watch/iPhone can reach this Mac on LAN.
HOST=0.0.0.0
PORT=8787

# OpenCV capture-card device mode settings. Try 0, 1, 2, etc. until capture-test shows the right feed.
CAPTURE_DEVICE_INDEX=0

# auto picks AVFoundation on macOS, DirectShow on Windows, V4L2 on Linux.
# You can override with: any, avfoundation, dshow, msmf, v4l2.
CAPTURE_BACKEND=auto

# Requested capture-card mode, like OBS's Video Capture Device resolution/FPS settings.
# Crop/resize happens later under IMAGE_* settings.
CAPTURE_WIDTH=1920
CAPTURE_HEIGHT=1080
CAPTURE_FPS=0
CAPTURE_FOURCC=
CAPTURE_BUFFER_SIZE=1
CAPTURE_STRICT_MODE=false
CAPTURE_MODE_TOLERANCE_PIXELS=8
CAPTURE_WARMUP_FRAMES=4
CAPTURE_TIMEOUT_SECONDS=4

# If the same low-res frame fingerprint is seen for this long, release/reopen
# the capture device and recapture once. Disable by setting this to false.
CAPTURE_STALE_WATCHDOG_ENABLED=true
STALE_FRAME_SECONDS=20
STALE_FRAME_SIGNATURE_SIZE=24
STALE_FRAME_DIFF_THRESHOLD=2.0
VIDEO_REACTIVATION_ATTEMPTS=1
VIDEO_REACTIVATION_PAUSE_SECONDS=1.0

# Fixed image transform applied after capture and before upload.
# Width/height of 0 means "use the remaining/full size" for crop, or
# "preserve aspect ratio" for output resize when only one output side is set.
IMAGE_CROP_LEFT=0
IMAGE_CROP_TOP=0
IMAGE_CROP_WIDTH=0
IMAGE_CROP_HEIGHT=0
IMAGE_OUTPUT_WIDTH=0
IMAGE_OUTPUT_HEIGHT=0
JPEG_QUALITY=92

# Save every request in its own folder with screenshots, prompt, response, and metadata.
REQUEST_LOG_ENABLED=true
REQUEST_LOG_ROOT=request_logs

# Optional: POST the result somewhere else after each request.
WATCH_CALLBACK_URL=
CALLBACK_TIMEOUT_SECONDS=6
LOG_LEVEL=INFO
